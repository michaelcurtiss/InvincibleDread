\par\pard\plain \ltrch\loch \f0\fs24\b0
\par\plain {\f0\fs24\b0 Thou from primeval nothingness didst call}
\par\plain {\f0\fs24\b0 First chaos, then existence;\hich\f0 \emdash \loch\f0 Lord! on Thee}
\par\plain {\f0\fs24\b0 Eternity had its foundation:\hich\f0 \emdash \loch\f0 all}
\par\plain {\f0\fs24\b0 Sprung forth from Thee:\hich\f0 \emdash \loch\f0 of light, joy, harmony,}
\par\plain {\f0\fs24\b0 Sole origin:\hich\f0 \emdash \loch\f0 all life, all beauty Thine.}
\par\plain {\f0\fs24\b0 Thy word created all, and doth create;}
\par\plain {\f0\fs24\b0 Thy splendor fills all space with rays divine.}
\par\plain {\f0\fs24\b0 Thou art, and wert, and shalt be! Glorious! Great!}
\par\plain {\f0\fs24\b0 Light-giving, life-sustaining Potentate!}}