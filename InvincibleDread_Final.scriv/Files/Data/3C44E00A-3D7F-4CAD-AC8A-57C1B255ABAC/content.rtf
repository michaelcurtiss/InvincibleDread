\paperw12240\paperh15840\margl1800\margr1800\margt1440\margb1440\f0\fs24\cf0
\pard\plain \fi720\sl288\slmult1\ltrch\loch \f0\fs24\b0\i0\cf1
\par\plain \f0\fs24\b0\i0\cf1
\par\plain \f0\fs24\b0\i0\cf1
\par\plain {\f0\fs24\b0\i0\cf1 Proto-religion -}
\par\plain {\f0\fs24\b0\i0\cf1 That tree over there fell down. Why?}
\par\plain {\f0\fs24\b0\i0\cf1 That mountain is larger than all the others. Why?}
\par\plain {\f0\fs24\b0\i0\cf1 Lightning flashed in the sky. Why?}
\par\plain {\f0\fs24\b0\i0\cf1 The river flooded and killed people. Why?}
\par\plain \f0\fs24\b0\i0\cf1
\par\plain {\f0\fs24\b0\i0\cf1 All of these questions once motivated religion.}
\par\plain \f0\fs24\b0\i0\cf1
\par\plain {\f0\fs24\b0\i0\cf1 Then comes a philosophical turn.}
\par\plain {\f0\fs24\b0\i0\cf1 Why should any of it exist?}
\par\plain \f0\fs24\b0\i0\cf1
\par\plain \f0\fs24\b0\i0\cf1
\par\plain {\f0\fs24\b0\i0\cf1 It begins with an observation of existence. This is very strange. Inevitably leads to a question: why should something exist instead of nothing?}
\par\plain \f0\fs24\b0\i0\cf1
\par\pard\plain \sa180\sb180\ltrch\loch {Parmenides argued:}
\par\pard\plain \li540\fi-270\sa180\sb180\ltrch\loch \ls1\ilvl0{\listtext	 \uc0\u8226 	}{\loch\af0\hich\af0\dbch\af0\uc1\u8220\'93What is, is.\u8221\'94}
\par\plain \ilvl0{\listtext	 \uc0\u8226 	}{\loch\af0\hich\af0\dbch\af0\uc1\u8220\'93What is not, is not.\u8221\'94}
\par\plain \ilvl0{\listtext	 \uc0\u8226 	}{Non\_being is impossible.}
\par\pard\plain \sa180\sb180\ltrch\loch {This is the earliest philosophical attempt to grapple with the idea that }{\f0\fs24\b1 being must be}{, and that }{\f0\fs24\b1 nothingness is incoherent}{.}
\par\plain 
\par\plain {Similar to the issue of law of identity}
\par\plain 
\par\pard\plain \ltrch\loch {Plato wrestles with the relationship between being and non\_being in the }{\f0\fs24\i1 Sophist}{, where he tries to explain how \loch\af0\hich\af0\dbch\af0\uc1\u8220\'93non\_being\u8221\'94 can be spoken of without contradiction. This is not the existential question yet, but it\u8217\'92s a crucial step. }
\par\plain 
\par\pard\plain \sa180\sb180\ltrch\loch {Aristotle introduces the idea of a }{\f0\fs24\b1 necessary being}{ (the Unmoved Mover). He doesn\loch\af0\hich\af0\dbch\af0\uc1\u8217\'92t ask \u8220\'93Why is there something rather than nothing?\u8221\'94 but he does ask:}
\par\pard\plain \li540\fi-270\sa180\sb180\ltrch\loch \ls2\ilvl0{\listtext	 \uc0\u8226 	}{What explains the existence of contingent beings?}
\par\plain \ilvl0{\listtext	 \uc0\u8226 	}{Must there be something that cannot not exist?}
\par\pard\plain \fi720\sl288\slmult1\ltrch\loch 
\par\pard\plain \sa180\sb180\ltrch\loch {He argues that:}
\par\pard\plain \li540\fi-270\sa180\sb180\ltrch\loch \ls3\ilvl0{\listtext	 \uc0\u8226 	}{Nothing is simpler.}
\par\plain \ilvl0{\listtext	 \uc0\u8226 	}{Something exists.}
\par\plain \ilvl0{\listtext	 \uc0\u8226 	}{Therefore, there must be a sufficient reason for existence.}
\par\plain \ilvl0{\listtext	 \uc0\u8226 	}{That reason is God, whose essence includes existence.}
\par\pard\plain \fi720\sl288\slmult1\ltrch\loch 
\par\pard\plain \sa180\sb180\ltrch\loch {\f0\fs24\b1 The question is meaningful and profound}{ (e.g., van Inwagen, Lowe, Swinburne).}
\par\plain {\f0\fs24\b1 The question is meaningless or ill\_posed}{ (e.g., Carnap, Wittgenstein, Ryle, some naturalists).}
\par\plain {\f0\fs24\b1 The question is coherent but unanswerable}{ (e.g., Nagel, Parfit, some modal metaphysicians).}
\par\plain 
\par\plain }